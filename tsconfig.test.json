{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "verbatimModuleSyntax": false,
    "strictFunctionTypes": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
